---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
}
const {
  title,
  description,
  canonical,
} = Astro.props
const ogImage = '/og.svg'
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preload" href="/fonts/jetbrainsmono.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/spacegrotesk.woff2" as="font" type="font/woff2" crossorigin />
</head>
<body>
  <div class="page">
    <div class="window">
      <slot />
    </div>
  </div>
</body>
</html>

<style>
  .page {
    min-height: 100vh;
    background: radial-gradient(120% 80% at 50% -10%, #110A22 0%, var(--bg-deep) 60%);
    padding: clamp(0px, 3vw, 40px);
    box-sizing: border-box;
  }
  .window {
    width: min(1080px, 100%);
    margin: 0 auto;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: clamp(0px, 1.2vw, 12px);
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(157, 92, 255, 0.05),
      0 50px 140px -50px rgba(157, 92, 255, 0.28);
  }
</style>
