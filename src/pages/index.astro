---
import '../styles/global.css'

const API = 'https://api.rustokwallet.com'

const tagColors = {
  rust: 'background:rgba(206,66,43,0.15);color:#e8705c;',
  eth: 'background:var(--indigo-dim);color:var(--indigo);',
  security: 'background:var(--danger-dim);color:var(--danger);',
  ai: 'background:rgba(168,85,247,0.15);color:#a855f7;',
  mobile: 'background:var(--accent-dim);color:var(--accent);',
  kernel: 'background:rgba(34,197,94,0.15);color:var(--safe);',
}

const roadmapItems = [
  { status: 'done', phase: 'Phase 1 — Done', title: 'txguard Engine + CLI', desc: 'Transaction parser, EVM simulator (revm), 8-rule security engine, GoPlus integration. Standalone Rust crate + CLI tool.', tags: [['rust','Rust'],['security','Security'],['eth','alloy-rs']] },
  { status: 'done', phase: 'Phase 2 — Done', title: 'Desktop Application', desc: 'Full desktop wallet via Tauri 2.0 + Leptos (Rust → WASM). Send, receive, analyze transactions. AES-256-GCM encrypted keystore.', tags: [['rust','Tauri 2.0'],['rust','Leptos'],['security','AES-256-GCM']] },
  { status: 'active', phase: 'Phase 3 — In Progress', title: 'Mobile (iOS + Android)', desc: 'Native mobile app via Tauri 2.0. Biometric unlock (Face ID / fingerprint), transaction history across 5 chains.', tags: [['mobile','iOS'],['mobile','Android'],['security','Biometric']] },
  { status: 'upcoming', phase: 'Phase 4', title: 'Cross-Chain Abstraction', desc: 'Unified balance across all chains. Intent-based routing via Across Protocol. One-click transfers between L1/L2.', tags: [['eth','Across Protocol'],['eth','Intents']] },
  { status: 'upcoming', phase: 'Phase 5', title: 'AI-Powered Assistant', desc: 'Natural language commands: "send 0.5 ETH to Alice". AI transaction explainer. Smart route optimization.', tags: [['ai','AI/NLP'],['ai','Explainer']] },
  { status: 'visionary', phase: 'Phase 6 — Vision', title: 'seL4 Hardened Runtime', desc: 'Minimal OS on formally verified seL4 microkernel. Rust userspace. First software wallet on a mathematically proven secure foundation.', tags: [['kernel','seL4 Microkernel'],['rust','Rust OS'],['security','Formally Verified']] },
]

const statusStyles = {
  done: { dot: 'border-color:var(--safe);background:var(--safe-dim);box-shadow:0 0 12px var(--safe-glow);', inner: 'width:8px;height:8px;background:var(--safe);', text: 'color:var(--safe);' },
  active: { dot: 'border-color:var(--accent);background:var(--accent-dim);box-shadow:0 0 12px var(--accent-glow);animation:pulse-dot 2s infinite;', inner: 'width:8px;height:8px;background:var(--accent);', text: 'color:var(--accent);' },
  upcoming: { dot: 'border-color:var(--text-dim);background:var(--bg);', inner: 'width:6px;height:6px;background:var(--text-dim);', text: 'color:var(--text-dim);' },
  visionary: { dot: 'border-color:var(--indigo);background:var(--indigo-dim);box-shadow:0 0 12px rgba(99,102,241,0.25);', inner: 'width:6px;height:6px;background:var(--indigo);', text: 'color:var(--indigo);' },
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rustok — Open-Source Rust Ethereum Wallet</title>
  <meta name="description" content="Open-source Rust Ethereum wallet with built-in transaction protection. Scan any address for free." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:image" content="/logo.png" />
  <meta property="og:title" content="Rustok — Open-Source Rust Ethereum Wallet" />
  <meta property="og:description" content="Open-source Rust wallet with built-in transaction protection. Scan any address for free." />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Header -->
<header style="position:fixed;top:0;left:0;right:0;z-index:100;padding:16px 0;background:rgba(8,8,15,0.8);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);">
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;">
    <div style="display:flex;align-items:center;gap:10px;font-weight:700;font-size:20px;letter-spacing:-0.02em;">
      <img src="/logo.png" alt="Rustok" width="32" height="32" style="border-radius:6px;" />
      Rustok
    </div>
    <ul style="display:flex;gap:32px;list-style:none;">
      <li><a href="#scanner" style="color:var(--text-muted);font-size:14px;font-weight:500;">Scanner</a></li>
      <li><a href="#features" style="color:var(--text-muted);font-size:14px;font-weight:500;">Features</a></li>
      <li><a href="#roadmap" style="color:var(--text-muted);font-size:14px;font-weight:500;">Roadmap</a></li>
      <li><a href="https://github.com/temrjan/rustok" target="_blank" style="color:var(--text-muted);font-size:14px;font-weight:500;">GitHub</a></li>
    </ul>
    <a href="https://github.com/temrjan/rustok" target="_blank" style="display:inline-flex;align-items:center;gap:8px;padding:8px 20px;background:var(--accent-dim);color:var(--accent);border:1px solid rgba(245,158,11,0.25);border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      Star on GitHub
    </a>
  </div>
</header>

<!-- Hero -->
<section style="padding:160px 0 80px;text-align:center;position:relative;">
  <div style="position:absolute;top:60px;left:50%;transform:translateX(-50%);width:600px;height:600px;background:radial-gradient(circle,var(--accent-glow) 0%,transparent 70%);opacity:0.15;pointer-events:none;"></div>
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;">
    <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;background:var(--accent-dim);border:1px solid rgba(245,158,11,0.2);border-radius:100px;font-size:13px;font-weight:500;color:var(--accent);margin-bottom:24px;">
      <span style="width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse-dot 2s infinite;"></span>
      Building in public
    </div>
    <h1 style="font-size:56px;font-weight:800;letter-spacing:-0.03em;line-height:1.1;margin-bottom:20px;">
      Scan any Ethereum address.<br>
      <span style="background:linear-gradient(135deg,var(--accent) 0%,#ff8c00 50%,var(--indigo) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">See the risk instantly.</span>
    </h1>
    <p style="font-size:18px;color:var(--text-muted);max-width:560px;margin:0 auto 48px;line-height:1.7;">
      Open-source Rust wallet with built-in transaction protection.
      No seed phrases. No closed code. Every commit is public.
    </p>
  </div>
</section>

<!-- Scanner -->
<section style="padding:0 0 100px;" id="scanner">
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;">
    <div class="glass" style="max-width:800px;margin:0 auto;padding:32px;">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
        <div style="width:36px;height:36px;background:var(--accent-dim);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;">&#x1f6e1;</div>
        <div>
          <h2 style="font-size:20px;font-weight:700;">txguard Scanner</h2>
          <span style="font-size:13px;color:var(--text-muted);">Powered by GoPlus Security API</span>
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-bottom:12px;" id="inputRow">
        <input type="text" id="addressInput" placeholder="0x... paste any Ethereum address" spellcheck="false"
          style="flex:1;padding:14px 18px;background:var(--surface);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:var(--mono);font-size:14px;" />
        <button id="scanBtn" onclick="runScan()"
          style="padding:14px 28px;background:linear-gradient(135deg,var(--accent),#e07800);color:#000;border:none;border-radius:10px;font-family:var(--font);font-size:15px;font-weight:700;cursor:pointer;white-space:nowrap;">Scan</button>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button onclick="loadExample('0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045')" style="padding:4px 12px;background:var(--safe-dim);color:var(--safe);border:none;border-radius:6px;font-size:12px;font-family:var(--font);cursor:pointer;font-weight:600;">Try: Vitalik.eth (safe)</button>
        <button onclick="loadExample('0x00000000A991C429eE2Ec6df19d40fe0c80088B8')" style="padding:4px 12px;background:var(--danger-dim);color:var(--danger);border:none;border-radius:6px;font-size:12px;font-family:var(--font);cursor:pointer;font-weight:600;">Try: Known scam</button>
      </div>

      <!-- Result -->
      <div id="resultSection" style="margin-top:24px;opacity:0;transform:translateY(12px);transition:all 0.4s ease;pointer-events:none;">
        <div class="glass" style="padding:24px;display:flex;gap:24px;align-items:flex-start;" id="resultCard">
          <div id="verdictBadge" style="flex-shrink:0;width:72px;height:72px;border-radius:16px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-weight:800;font-size:24px;gap:2px;"></div>
          <div style="flex:1;">
            <h3 id="resultTitle" style="font-size:18px;font-weight:700;margin-bottom:6px;"></h3>
            <p id="resultDesc" style="font-size:14px;color:var(--text-muted);margin-bottom:12px;"></p>
            <div id="findingsContainer" style="display:flex;flex-wrap:wrap;gap:8px;"></div>
          </div>
        </div>
      </div>

      <!-- Loading -->
      <div id="loadingSection" style="margin-top:24px;display:none;text-align:center;padding:24px;">
        <div style="color:var(--accent);font-size:14px;">Scanning address...</div>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section style="padding:100px 0;" id="features">
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;">
    <div style="text-align:center;margin-bottom:56px;">
      <h2 style="font-size:36px;font-weight:800;letter-spacing:-0.02em;margin-bottom:12px;">Built different</h2>
      <p style="color:var(--text-muted);font-size:16px;">Not another JavaScript wallet. Built from scratch in Rust for security and speed.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;">
      <div class="glass" style="padding:28px;">
        <div style="width:44px;height:44px;background:var(--danger-dim);color:var(--danger);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px;">&#x1f6e1;</div>
        <h3 style="font-size:17px;font-weight:700;margin-bottom:8px;">Transaction Protection</h3>
        <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Every transaction is analyzed before signing. Unlimited approvals, phishing contracts, scam addresses &mdash; caught before you lose funds.</p>
      </div>
      <div class="glass" style="padding:28px;">
        <div style="width:44px;height:44px;background:var(--accent-dim);color:var(--accent);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px;">&#x26d3;</div>
        <h3 style="font-size:17px;font-weight:700;margin-bottom:8px;">Multi-chain</h3>
        <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Ethereum, Arbitrum, Base, Optimism, zkSync Era. One wallet, unified balance. Cross-chain transfers via Across Protocol (coming soon).</p>
      </div>
      <div class="glass" style="padding:28px;">
        <div style="width:44px;height:44px;background:var(--indigo-dim);color:var(--indigo);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px;">&#x1f310;</div>
        <h3 style="font-size:17px;font-weight:700;margin-bottom:8px;">Fully Open Source</h3>
        <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Every line of code is public. Audit it yourself. No hidden backdoors. No telemetry. Your keys never leave your device.</p>
      </div>
      <div class="glass" style="padding:28px;">
        <div style="width:44px;height:44px;background:rgba(234,179,8,0.15);color:#eab308;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px;">&#x26a1;</div>
        <h3 style="font-size:17px;font-weight:700;margin-bottom:8px;">Written in Rust</h3>
        <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Memory-safe, zero-cost abstractions, no garbage collector. Desktop, iOS, Android from a single codebase via Tauri 2.0.</p>
      </div>
    </div>
  </div>
</section>

<!-- Roadmap -->
<section style="padding:100px 0;" id="roadmap">
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;">
    <div style="text-align:center;margin-bottom:56px;">
      <h2 style="font-size:36px;font-weight:800;letter-spacing:-0.02em;margin-bottom:12px;">Roadmap</h2>
      <p style="color:var(--text-muted);font-size:16px;">From transaction security engine to a formally verified wallet runtime.</p>
    </div>
    <div style="position:relative;max-width:720px;margin:0 auto;" id="timeline">
      <div style="position:absolute;left:28px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--accent),var(--indigo),var(--text-dim));opacity:0.3;"></div>

      {roadmapItems.map(item => {
        const s = statusStyles[item.status as keyof typeof statusStyles]
        return (
          <div style="position:relative;padding-left:72px;padding-bottom:40px;">
            <div style={`position:absolute;left:18px;top:4px;width:22px;height:22px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;${s.dot}`}>
              <div style={`border-radius:50%;${s.inner}`}></div>
            </div>
            <div style={`font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;${s.text}`}>{item.phase}</div>
            <div style="font-size:18px;font-weight:700;margin-bottom:6px;">{item.title}</div>
            <div style="font-size:14px;color:var(--text-muted);line-height:1.6;">{item.desc}</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
              {item.tags.map(([type, label]) => (
                <span style={`padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;font-family:var(--mono);${tagColors[type as keyof typeof tagColors] || ''}`}>{label}</span>
              ))}
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>

<!-- CTA -->
<section style="padding:80px 0;text-align:center;">
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;">
    <div class="glass" style="max-width:640px;margin:0 auto;padding:48px 40px;position:relative;overflow:hidden;">
      <div style="position:absolute;top:-80px;left:50%;transform:translateX(-50%);width:400px;height:400px;background:radial-gradient(circle,var(--accent-glow) 0%,transparent 70%);opacity:0.1;pointer-events:none;"></div>
