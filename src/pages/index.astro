</section>

<!-- Stats -->
<section style="padding:60px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:32px;text-align:center;">
      <div><div style="font-size:36px;font-weight:800;color:var(--accent);letter-spacing:-0.02em;">103+</div><div style="font-size:14px;color:var(--text-muted);margin-top:4px;">Tests passing</div></div>
      <div><div style="font-size:36px;font-weight:800;color:var(--accent);letter-spacing:-0.02em;">5</div><div style="font-size:14px;color:var(--text-muted);margin-top:4px;">Chains supported</div></div>
      <div><div style="font-size:36px;font-weight:800;color:var(--accent);letter-spacing:-0.02em;">8</div><div style="font-size:14px;color:var(--text-muted);margin-top:4px;">Security rules</div></div>
      <div><div style="font-size:36px;font-weight:800;color:var(--accent);letter-spacing:-0.02em;">100%</div><div style="font-size:14px;color:var(--text-muted);margin-top:4px;">Open source</div></div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer style="padding:48px 0;text-align:center;">
  <div style="max-width:1120px;margin:0 auto;padding:0 24px;">
    <div style="display:flex;justify-content:center;gap:32px;margin-bottom:24px;">
      <a href="https://github.com/temrjan/rustok" target="_blank" style="color:var(--text-muted);font-size:14px;">GitHub</a>
      <a href="https://x.com/rustokwallet" target="_blank" style="color:var(--text-muted);font-size:14px;">X (Twitter)</a>
      <a href="#scanner" style="color:var(--text-muted);font-size:14px;">Try Scanner</a>
      <a href="/privacy" style="color:var(--text-muted);font-size:14px;">Privacy</a>
    </div>
    <div style="font-size:13px;color:var(--text-dim);">&copy; 2026 Rustok. Open-source Rust Ethereum Wallet.</div>
    <div style="margin-top:12px;font-size:11px;color:var(--text-dim);font-style:italic;">Experimental software. Not financial advice. Use at your own risk.</div>
  </div>
</footer>

<script define:vars={{ API }}>
  function loadExample(addr) {
    document.getElementById('addressInput').value = addr;
    runScan();
  }

  async function runScan() {
    const addr = document.getElementById('addressInput').value.trim();
    if (!addr) return;

    const resultEl = document.getElementById('resultSection');
    const loadingEl = document.getElementById('loadingSection');

    resultEl.style.opacity = '0';
    resultEl.style.pointerEvents = 'none';
    loadingEl.style.display = 'block';

    try {
      const resp = await fetch(`${API}/check-address`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ address: addr }),
      });

      const data = await resp.json();

      if (!resp.ok) {
        showError(data.message || 'Request failed');
        return;
      }

      const badge = document.getElementById('verdictBadge');
      const isDanger = data.is_malicious;
      badge.style.background = isDanger ? 'var(--danger-dim)' : 'var(--safe-dim)';
      badge.style.color = isDanger ? 'var(--danger)' : 'var(--safe)';
      badge.style.boxShadow = `0 0 30px ${isDanger ? 'var(--danger-glow)' : 'var(--safe-glow)'}`;
      badge.innerHTML = `<span style="font-size:20px;">${isDanger ? '!' : '&#x2713;'}</span><small style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">${data.risk_level}</small>`;

      document.getElementById('resultTitle').textContent = isDanger
        ? 'Malicious address detected'
        : 'Address appears safe';
      document.getElementById('resultDesc').textContent = isDanger
        ? 'This address has been flagged for malicious activity. Do NOT interact.'
        : 'No malicious activity detected by GoPlus Security.';

      const fc = document.getElementById('findingsContainer');
      fc.innerHTML = '';
      if (data.risks && data.risks.length > 0) {
        data.risks.forEach(r => {
          const tag = document.createElement('span');
          tag.style.cssText = 'padding:4px 12px;border-radius:6px;font-size:12px;font-weight:600;font-family:var(--mono);background:var(--danger-dim);color:var(--danger);';
          tag.textContent = r;
          fc.appendChild(tag);
        });
      } else if (!isDanger) {
        const tag = document.createElement('span');
        tag.style.cssText = 'padding:4px 12px;border-radius:6px;font-size:12px;font-weight:600;font-family:var(--mono);background:var(--safe-dim);color:var(--safe);';
        tag.textContent = 'No threats found';
        fc.appendChild(tag);
      }

      loadingEl.style.display = 'none';
      resultEl.style.opacity = '1';
      resultEl.style.transform = 'translateY(0)';
      resultEl.style.pointerEvents = 'auto';

    } catch (err) {
      showError('Network error. Please try again.');
    }
  }

  function showError(msg) {
    document.getElementById('loadingSection').style.display = 'none';
    const resultEl = document.getElementById('resultSection');
    const badge = document.getElementById('verdictBadge');
    badge.style.background = 'var(--warn-dim)';
    badge.style.color = 'var(--warn)';
    badge.style.boxShadow = '0 0 30px var(--accent-glow)';
    badge.innerHTML = '<span style="font-size:20px;">?</span><small style="font-size:10px;font-weight:600;text-transform:uppercase;">Error</small>';
    document.getElementById('resultTitle').textContent = 'Scan failed';
    document.getElementById('resultDesc').textContent = msg;
    document.getElementById('findingsContainer').innerHTML = '';
    resultEl.style.opacity = '1';
    resultEl.style.transform = 'translateY(0)';
    resultEl.style.pointerEvents = 'auto';
  }

  document.getElementById('addressInput').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') runScan();
  });

  // Expose to inline onclick handlers
  window.runScan = runScan;
  window.loadExample = loadExample;
</script>

</body>
</html>
