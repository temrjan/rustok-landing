---
import SectionHead from './SectionHead.astro'
import CodeBlock from './CodeBlock.astro'
---

<section id="install" class="section" data-reveal>
  <SectionHead cmd="install" title="Set up in two steps." />

  <div class="prereq">
    <span class="i">i</span>
    <span><span class="strong">Prerequisites — </span>Docker running + an Ethereum RPC URL (an Alchemy key URL is best; a public RPC works for testing).</span>
  </div>

  <div class="step">
    <div class="num">01</div>
    <div>
      <div class="step-title">Create your wallet</div>
      <div class="step-sub">Prints an address + 24 words — visible only in your terminal.</div>
      <CodeBlock label="create-wallet command"><span class="hl-cmd">docker</span> run -it --rm -v rustok-wallet:/data \
  -e RUSTOK_KEYRING_PASSWORD=<span class="hl-str">"choose-a-strong-password"</span> \
  ghcr.io/rustok-org/rustok-wallet:latest <span class="hl-kw">create-wallet</span></CodeBlock>
      <div class="note">Recovery = the 24 words (importable into any standard wallet, e.g. MetaMask) or the Docker volume + password.</div>
    </div>
  </div>

  <div class="step">
    <div class="num">02</div>
    <div>
      <div class="step-title">Add the MCP server config</div>
      <div class="step-sub">Drop this into your MCP client.</div>
      <CodeBlock label="MCP server config" muted>&#123;
  <span class="hl-cmd">"mcpServers"</span>: &#123;
    <span class="hl-cmd">"rustok-wallet"</span>: &#123;
      <span class="hl-cmd">"command"</span>: <span class="hl-str">"docker"</span>,
      <span class="hl-cmd">"args"</span>: [<span class="hl-str">"run"</span>,<span class="hl-str">"-i"</span>,<span class="hl-str">"--rm"</span>,<span class="hl-str">"--init"</span>,
               <span class="hl-str">"-v"</span>,<span class="hl-str">"rustok-wallet:/data"</span>,
               <span class="hl-str">"-e"</span>,<span class="hl-str">"RUSTOK_KEYRING_PASSWORD"</span>,
               <span class="hl-str">"-e"</span>,<span class="hl-str">"RUSTOK_ALLOWED_CHAINS=1,8453"</span>,
               <span class="hl-str">"-e"</span>,<span class="hl-str">"RUSTOK_RPC_URLS_1"</span>,
               <span class="hl-str">"ghcr.io/rustok-org/rustok-wallet:latest"</span>],
      <span class="hl-cmd">"env"</span>: &#123;
        <span class="hl-cmd">"RUSTOK_KEYRING_PASSWORD"</span>: <span class="hl-str">"..."</span>,
        <span class="hl-cmd">"RUSTOK_RPC_URLS_1"</span>: <span class="hl-str">"https://your-rpc"</span>
      &#125;
    &#125;
  &#125;
&#125;</CodeBlock>
      <div class="note">Read-only agent? Set <span class="mono-muted">RUSTOK_MCP_CAPABILITIES=read_wallet</span>.</div>
    </div>
  </div>
</section>

<style>
  .prereq {
    display: flex; align-items: flex-start; gap: 11px;
    background: rgba(157, 92, 255, 0.06); border: 1px solid var(--border-soft); border-radius: 10px;
    padding: 14px 16px; margin-bottom: 30px;
    font-size: 13px; line-height: 1.55; color: var(--text-2);
  }
  .i { color: var(--amethyst); font-weight: 700; }
  .strong { color: var(--text); }

  .step {
    display: grid; grid-template-columns: auto 1fr;
    gap: clamp(14px, 2.5vw, 26px); margin-bottom: 26px;
  }
  .step:last-child { margin-bottom: 0; }
  .num { font-family: var(--display); font-weight: 700; font-size: clamp(22px, 3vw, 34px); color: var(--dim-3); line-height: 1; }
  .step-title { font-size: 14px; color: var(--text); font-weight: 600; margin-bottom: 4px; }
  .step-sub { font-size: 12.5px; color: var(--muted-2); margin-bottom: 12px; }
  .note { font-size: 12px; color: var(--muted-2); margin-top: 11px; line-height: 1.55; }
  .mono-muted { color: var(--muted); }
</style>
