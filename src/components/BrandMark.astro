---
/**
 * Rustok brand mark — a faceted Ethereum-style octahedron (two pyramids + a
 * gap at the girdle) in the Rustok palette: amethyst body with a teal accent
 * facet. Solid fills only (no gradient ids) so it renders many times per page.
 * Native aspect ratio 256:417; `size` is the height.
 */
interface Props {
  size?: number
  class?: string
  title?: string
}
const { size = 22, class: className, title = 'Rustok' } = Astro.props
const width = Math.round((size * 256) / 417)
---

<svg
  width={width}
  height={size}
  viewBox="0 0 256 417"
  fill="none"
  role="img"
  aria-label={title}
  class={className}
>
  <!-- crown — outer slopes -->
  <polygon points="128,0 0,212.32 128,287.96" fill="#B27DFF" />
  <polygon points="128,0 256,212.32 128,287.96" fill="#16E0C3" />
  <!-- crown — front faces (drawn over the slopes) -->
  <polygon points="0,212.32 128,287.96 128,154.16" fill="#7A45CC" />
  <polygon points="256,212.32 128,287.96 128,154.16" fill="#9D5CFF" />
  <!-- pavilion -->
  <polygon points="128,416.9 128,312.19 0,236.59" fill="#9D5CFF" />
  <polygon points="128,416.9 128,312.19 256,236.59" fill="#7A45CC" />
</svg>
