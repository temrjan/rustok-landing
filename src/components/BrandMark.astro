---
/**
 * Rustok brand mark — a faceted amethyst+teal crystal (TZ §4).
 * Solid fills only (no gradient ids) so it can be rendered many times
 * on one page without id collisions.
 */
interface Props {
  size?: number
  class?: string
  title?: string
}
const { size = 22, class: className, title = 'Rustok' } = Astro.props
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  role="img"
  aria-label={title}
  class={className}
>
  <path d="M12 1.6 L3.6 9.6 L12 9.6 Z" fill="#9D5CFF" />
  <path d="M12 1.6 L20.4 9.6 L12 9.6 Z" fill="#16E0C3" />
  <path d="M3.6 9.6 L12 9.6 L12 22.4 Z" fill="#7A45CC" />
  <path d="M20.4 9.6 L12 9.6 L12 22.4 Z" fill="#9D5CFF" />
  <path
    d="M12 1.6 L3.6 9.6 L12 22.4 L20.4 9.6 Z"
    stroke="#C9A2FF"
    stroke-opacity="0.35"
    stroke-width="0.6"
    stroke-linejoin="round"
  />
</svg>
