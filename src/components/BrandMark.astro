---
/**
 * Rustok brand mark — a faceted amethyst+teal crystal (TZ §4).
 * Solid fills only (no gradient ids) so it can be rendered many times
 * on one page without id collisions.
 */
interface Props {
  size?: number
  class?: string
  title?: string
}
const { size = 22, class: className, title = 'Rustok' } = Astro.props
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  role="img"
  aria-label={title}
  class={className}
>
  <path d="M12 2.5 L2.8 12 L21.2 12 Z" fill="#16E0C3" />
  <path d="M2.8 12 L21.2 12 L12 21.5 Z" fill="#9D5CFF" />
  <path
    d="M12 2.5 L2.8 12 L12 21.5 L21.2 12 Z"
    stroke="#C9A2FF"
    stroke-opacity="0.35"
    stroke-width="0.6"
    stroke-linejoin="round"
  />
  <path d="M12 2.5 L12 21.5" stroke="#C9A2FF" stroke-opacity="0.2" stroke-width="0.6" />
</svg>
